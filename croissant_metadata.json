{
  "@context": {
    "@language": "en",
    "@vocab": "https://schema.org/",
    "cr": "http://mlcommons.org/croissant/",
    "sc": "https://schema.org/"
  },
  "@type": "sc:Dataset",
  "name": "DurableUnEvaluationResults",
  "description": "Model evaluation scores (FA, RA, Q-INT4, Q-INT8, MIA-AUC, cert) from machine unlearning experiments evaluating multiple methods on LLaMA-3-8B-Instruct with the TOFU benchmark.",
  "url": "https://github.com/neurips26/UnifiedUnl",
  "version": "1.0.0",
  "license": "https://opensource.org/licenses/MIT",
  "datePublished": "2026-04-18",
  "creator": {
    "@type": "sc:Person",
    "name": "Anonymous"
  },
  "citation": "Anonymous. DurableUn: INT4 Quantization as a Recovery Attack on Machine Unlearning. NeurIPS 2026.",
  "keywords": [
    "machine unlearning",
    "quantization",
    "INT4",
    "LLM",
    "privacy",
    "evaluation",
    "TOFU"
  ],
  "distribution": [
    {
      "@type": "sc:FileSet",
      "@id": "results_csvs",
      "name": "results_csvs",
      "description": "Collection of CSV result files for all experimental runs.",
      "contentUrl": "results/",
      "encodingFormat": "text/csv",
      "http://mlcommons.org/schema/includes": "**/*.csv"
    }
  ],
  "recordSet": [
    {
      "@type": "cr:RecordSet",
      "name": "evaluation_results",
      "description": "Per-run evaluation metrics from machine unlearning experiments.",
      "field": [
        {
          "@type": "cr:Field",
          "name": "method",
          "dataType": "sc:Text",
          "description": "Unlearning method name"
        },
        {
          "@type": "cr:Field",
          "name": "dataset",
          "dataType": "sc:Text",
          "description": "Evaluation benchmark"
        },
        {
          "@type": "cr:Field",
          "name": "seed",
          "dataType": "sc:Integer",
          "description": "Random seed"
        },
        {
          "@type": "cr:Field",
          "name": "forget_acc",
          "dataType": "sc:Float",
          "description": "Forget accuracy (FA)"
        },
        {
          "@type": "cr:Field",
          "name": "retain_acc",
          "dataType": "sc:Float",
          "description": "Retain accuracy (RA)"
        },
        {
          "@type": "cr:Field",
          "name": "quant_int8",
          "dataType": "sc:Float",
          "description": "INT8 quantized forget accuracy"
        },
        {
          "@type": "cr:Field",
          "name": "quant_int4",
          "dataType": "sc:Float",
          "description": "INT4 quantized forget accuracy"
        },
        {
          "@type": "cr:Field",
          "name": "ra_int4",
          "dataType": "sc:Float",
          "description": "Retain accuracy after INT4"
        },
        {
          "@type": "cr:Field",
          "name": "cert",
          "dataType": "sc:Text",
          "description": "Durability certificate (Y/N)"
        },
        {
          "@type": "cr:Field",
          "name": "wall_min",
          "dataType": "sc:Float",
          "description": "Training time in minutes"
        }
      ]
    }
  ]
}
